# -----------------------------
# [DB] 데이터베이스 접속 정보
# -----------------------------
POSTGRES_USER=daypoo
POSTGRES_PASSWORD=daypoo1234
POSTGRES_DB=daypoo_db
DB_HOST=localhost
DB_PORT=5432

# -----------------------------
# [Redis] 레디스 접속 정보
# -----------------------------
REDIS_HOST=localhost
REDIS_PORT=6379

# -----------------------------
# [Security] 인증 및 토큰 설정
# -----------------------------
# 256비트 이상의 유효한 Base64 인코딩 키 필요
JWT_SECRET_KEY=YOUR_SECURE_BASE64_KEY_HERE
FRONTEND_URL=http://localhost:5173

# -----------------------------
# [API] 외부 연동 정보
# -----------------------------
PUBLIC_DATA_API_KEY=YOUR_PUBLIC_DATA_API_KEY
AI_SERVICE_URL=http://localhost:8000

# 토스페이먼츠 시크릿 키 (콜론 없이 순수 키만 입력)
TOSS_SECRET_KEY=YOUR_TOSS_SECRET_KEY
# 토스페이먼츠 클라이언트 키 (프론트엔드 VITE 대응)
VITE_TOSS_CLIENT_KEY=YOUR_TOSS_CLIENT_KEY

# -----------------------------
# [OAuth2] 소셜 로그인 정보
# -----------------------------
KAKAO_CLIENT_ID=YOUR_KAKAO_CLIENT_ID
KAKAO_CLIENT_SECRET=YOUR_KAKAO_CLIENT_SECRET
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# -----------------------------
# Gmail SMTP 설정 (비밀번호 찾기용)
# -----------------------------
MAIL_USERNAME=YOUR_GMAIL_ID@gmail.com
MAIL_PASSWORD=YOUR_GMAIL_APP_PASSWORD
